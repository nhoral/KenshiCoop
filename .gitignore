# Public-repo export staging (pushed to github.com/nhoral/KenshiCoop, not tracked here)
dist/public-export/

# Build outputs (all configs: Debug / Harness / Release)
src/plugin/x64/
build/
dist/*.exe
# Generated packages + mutable DLL artifacts under dist/ (the canonical shipped
# DLL is built on demand and its SHA-256 is recorded in the kit's PROVENANCE.json;
# we do not track multiple mutable copies). dist/mods/ (RE_Kenshi.json + .mod
# template) stays tracked - it is a packaging SOURCE, not an output.
dist/*.zip
dist/*.dll
dist/mod-kit/
dist/remote-kit/
dist/KenshiCoop-remote-kit-*.zip

# Manual co-op session captures (logs + screenshots)
tools/manual-sessions/

# Vendored dependency source (fetched via clone/git-LFS, not committed; ~500MB)
third_party/enet/enet/
third_party/KenshiLib_deps/

# Test-run artifacts (logs, screenshots, verdicts, history)
tools/test-runs/
tools/*.log
tools/_*.log

# Ad-hoc debug scratch scripts and captured screenshots
tools/_*.ps1
tools/_wip_*.dll
tools/float_fix*/
tools/p*_validate/
tools/last_dev_cycle.txt

# Downloaded toolchain installers (large Microsoft binaries)
tools/*.exe

# Root-level run logs (build/deploy/run drivers)
/*.log

# Machine-specific config (committed template: scripts/lan.config.example.json)
scripts/lan.config.json

# Local assets / working notes (design docs, spikes, recordings, frames) - kept
# locally, not tracked in the repo.
resources/

# Stray shell artifact
nul

# Local-only maintainer notes (release process, etc.) - not for the public repo
*.local.md
