 {
+    if (socketHooks != NULL && socketHooks -> socket_destroy != NULL)
+    {
+      socketHooks -> socket_destroy (socket);
+      return;
+    }
+
     if (socket != INVALID_SOCKET)
       closesocket (socket);
 }
