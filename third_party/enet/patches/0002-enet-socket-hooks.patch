Optional datagram-transport hooks for ENet 1.3.18 (KenshiCoop Steam P2P
transport). Adds an ENetSocketHooks struct + enet_set_socket_hooks(): when
installed, enet_socket_{create,bind,send,receive,wait,destroy} delegate to the
hooks instead of Winsock UDP, so the entire ENet protocol can be tunnelled
over another datagram transport (Steam P2P). NULL (default) = stock UDP.

Apply from the repo root after fetching ENet and applying 0001 (the vendored
source under third_party/enet/enet/ is git-ignored):

    git apply third_party/enet/patches/0002-enet-socket-hooks.patch

--- a/third_party/enet/enet/include/enet/enet.h
+++ b/third_party/enet/enet/include/enet/enet.h
@@ -510,6 +510,23 @@ ENET_API int        enet_socket_shutdown (ENetSocket, ENetSocketShutdown);
 ENET_API void       enet_socket_destroy (ENetSocket);
 ENET_API int        enet_socketset_select (ENetSocket, ENetSocketSet *, ENetSocketSet *, enet_uint32);
 
+/** Optional datagram-transport hooks. When installed (non-NULL struct), the
+    enet_socket_* functions delegate to these instead of Winsock UDP, letting a
+    caller tunnel the entire ENet protocol over another datagram transport
+    (e.g. Steam P2P). Any NULL member falls back to the stock UDP path for that
+    function. Install BEFORE enet_host_create; uninstall with NULL. */
+typedef struct _ENetSocketHooks
+{
+   ENetSocket (ENET_CALLBACK * socket_create)  (ENetSocketType);
+   int        (ENET_CALLBACK * socket_bind)    (ENetSocket, const ENetAddress *);
+   int        (ENET_CALLBACK * socket_send)    (ENetSocket, const ENetAddress *, const ENetBuffer *, size_t);
+   int        (ENET_CALLBACK * socket_receive) (ENetSocket, ENetAddress *, ENetBuffer *, size_t);
+   int        (ENET_CALLBACK * socket_wait)    (ENetSocket, enet_uint32 *, enet_uint32);
+   void       (ENET_CALLBACK * socket_destroy) (ENetSocket);
+} ENetSocketHooks;
+
+ENET_API void enet_set_socket_hooks (const ENetSocketHooks * hooks);
+
 /** @} */
 
 /** @defgroup Address ENet address functions
--- a/third_party/enet/enet/win32.c
+++ b/third_party/enet/enet/win32.c
@@ -12,6 +12,15 @@
 
 static enet_uint32 timeBase = 0;
 
+/* Optional datagram-transport hooks (see enet.h). NULL = stock Winsock UDP. */
+static const ENetSocketHooks * socketHooks = NULL;
+
+void
+enet_set_socket_hooks (const ENetSocketHooks * hooks)
+{
+    socketHooks = hooks;
+}
+
 int
