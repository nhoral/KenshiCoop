 {
@@ -144,6 +153,9 @@ enet_socket_bind (ENetSocket socket, const ENetAddress * address)
 {
     struct sockaddr_in sin;
 
+    if (socketHooks != NULL && socketHooks -> socket_bind != NULL)
+      return socketHooks -> socket_bind (socket, address);
+
     memset (& sin, 0, sizeof (struct sockaddr_in));
 
     sin.sin_family = AF_INET;
@@ -188,6 +200,9 @@ enet_socket_listen (ENetSocket socket, int backlog)
 ENetSocket
 enet_socket_create (ENetSocketType type)
 {
+    if (socketHooks != NULL && socketHooks -> socket_create != NULL)
+      return socketHooks -> socket_create (type);
+
     return socket (PF_INET, type == ENET_SOCKET_TYPE_DATAGRAM ? SOCK_DGRAM : SOCK_STREAM, 0);
 }
 
@@ -315,6 +330,12 @@ enet_socket_shutdown (ENetSocket socket, ENetSocketShutdown how)
